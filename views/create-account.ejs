<%- include("../views/partials/header.ejs") %>

<main class="container d-flex justify-content-center align-items-center" style="min-height:70vh;">

  <div class="card shadow p-4" style="max-width: 500px; width:100%;">

    <h3 class="text-center mb-4">Create Account</h3>

    <form action="/create-account" method="POST">

      <div class="mb-3">
        <label for="fName" class="form-label">First Name</label>
        <input
          type="text"
          class="form-control"
          id="fName"
          name="fName"
          required
        >
      </div>

      <div class="mb-3">
        <label for="lName" class="form-label">Last Name</label>
        <input
          type="text"
          class="form-control"
          id="lName"
          name="lName"
          required
        >
      </div>

      <div class="mb-3">
        <label for="email" class="form-label">Email Address</label>
        <input
          type="email"
          class="form-control"
          id="email"
          name="email"
          value="<%= currentUser.email %>"
          required
        >
      </div>

      <h5 class="mt-4 mb-2">Select Role</h5>
      <div class="mb-4">
        <div class="form-check">
          <input class="form-check-input" type="radio" id="admin" name="role" value="Admin">
          <label class="form-check-label" for="admin">Admin</label>
        </div>
        <div class="form-check">
          <input class="form-check-input" type="radio" id="depHead" name="role" value="Department Head">
          <label class="form-check-label" for="depHead">Department Head</label>
        </div>
        <div class="form-check">
          <input class="form-check-input" type="radio" id="associate" name="role" value="Associate" required>
          <label class="form-check-label" for="associate">Associate</label>
        </div>
      </div>

      <button type="submit" class="btn btn-primary w-100" style="color: black;">Create Account</button>

    </form>

  </div>

</main>

<%- include("../views/partials/footer.ejs") %>