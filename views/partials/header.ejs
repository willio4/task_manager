<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Task Manager</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="styles.css" />
  </head>
    <nav id="top-nav" class="d-flex flex-row">
      <div class="container py-1 flex-grow-1">
        <h1>Task Manager</h1>
      </div>
      <% if(currentUser) { %>
        <p class="align-self-center text-white m-0"><%= currentUser.email %></p>
        <a href="/logout" class="align-self-center">
          <button class="btn text-white creds">Logout</button>
        </a>
      <% } else { %>
        <a href="/login" class="align-self-center">
          <button class="btn text-white creds">Login</button>
        </a>
        <a href="/signup" class="align-self-center">
          <button class="btn text-white creds">Sign Up</button>
        </a>
      <% } %> 
    </nav>

    <nav id="bottom-nav">
      <div class="container text-center">
        <div class="d-flex flex-row justify-content-start gap-3">
          <button class="btn text-white fw-semibold">Dashboard</button>
          <button class="btn text-white fw-semibold">Task</button>
          <button class="btn text-white fw-semibold">My Work</button>
          <button class="btn text-white fw-semibold">Activity</button>
          <button class="btn text-white fw-semibold">Health</button>
          <button class="btn text-white fw-semibold">Admin</button>
        </div>
      </div>
    </nav>