<%- include("../views/partials/header.ejs") %>
<main>
  <div class="container my-4">
    <h2>Health Check</h2>
    <p class="lead">All systems are operational.</p>
    <div class="d-flex flex-column">
      <!-- Data Department -->
      <p class="d-inline-flex" id="dataDepChart">
        <button
          class="btn btn-primary"
          style="color: black;"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#collapseData"
          aria-expanded="false"
          aria-controls="collapseData"
        >
          Data Department
        </button>
      </p>
      <div class="collapse" id="collapseData">
        <div class="card card-body mb-3">
          <div class="row health-chart">
            <canvas class="col-md-6" id="DataChart"></canvas>
            <div class="col">
              <div
                class="row justify-content-center h-50 align-items-center"
              >
                <h5 class="text-center">Stuck Tasks</h5>
                <ul>
                  <% if(stuckTasks.Data && stuckTasks.Data.length > 0) { stuckTasks.Data.forEach(task => { %> 
                    <li><%= task.first_name %> - "<%= task.title %>" </li>
                  <% }) } else { %>
                    <p class="text-center m-0">No Stuck tasks</p>
                  <% } %>
                </ul>

              </div>
              <div
                class="row justify-content-center h-50 w-100 align-items-center"
              >
                <canvas id="DataPieChart"></canvas>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Marketing Department -->
      <p class="d-inline-flex">
        <button
          class="btn btn-primary"
          style="color: black;"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#collapseMarketing"
          aria-expanded="false"
          aria-controls="collapseExample"
        >
          Marketing Department
        </button>
      </p>
      <div class="collapse" id="collapseMarketing">
        <div class="card card-body mb-3">
          <div class="row health-chart">
            <canvas class="col-md-6" id="MarketingChart"></canvas>
            <div class="col">
              <div
                class="row justify-content-center h-50 align-items-center"
              >
                <h5 class="text-center">Stuck Tasks</h5>
                <ul>
                  <% if(stuckTasks.Marketing && stuckTasks.Marketing.length > 0) { stuckTasks.Marketing.forEach(task => { %> 
                    <li><%= task.first_name %> - "<%= task.title %>" </li>
                  <% }) } else { %>
                    <p class="text-center m-0">No Stuck tasks</p>
                  <% } %>
                </ul>
              </div>
              <div
                class="row justify-content-center h-50 align-items-center"
              >
                <canvas id="MarketingPieChart"></canvas>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Operations Department -->
      <p class="d-inline-flex">
        <button
          class="btn btn-primary"
          style="color: black;"
          type="button"
          data-bs-toggle="collapse"
          data-bs-target="#collapseOperations"
          aria-expanded="false"
          aria-controls="collapseExample"
        >
          Operations Department
        </button>
      </p>
      <div class="collapse" id="collapseOperations">
        <div class="card card-body mb-3">
          <div class="row health-chart">
            <canvas class="col-md-6" id="OperationsChart"></canvas>
            <div class="col">
              <div
                class="row justify-content-center h-50 align-items-center"
              >
                <h5 class="text-center">Stuck Tasks</h5>
                <ul>
                  <% if(stuckTasks.Operations && stuckTasks.Operations.length > 0) { stuckTasks.Operations.forEach(task => { %> 
                    <li><%= task.first_name %> - "<%= task.title %>" </li>
                  <% }) } else { %>
                    <p class="text-center m-0">No Stuck tasks</p>
                  <% } %>
                </ul>
              </div>
              <div
                class="row justify-content-center h-50 align-items-center"
              >
                <canvas id="OperationsPieChart"></canvas>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  const departmentBarData = <%- JSON.stringify(barChart) %>;



  document.querySelectorAll(".collapse").forEach((collapse) => {
    collapse.addEventListener("shown.bs.collapse", () => {
      const button = document.querySelector(
        `[data-bs-target="#${collapse.id}"]`
      );
      if (button) {
        button.scrollIntoView({ behavior: "smooth", block: "start" });
      }
    });
  });

  Object.entries(departmentBarData).forEach(([department, users]) => {
    const canvas = document.getElementById(`${department}Chart`);
    if (!canvas) return;

    const labels = users.map((u) => u.user);
    const completed = users.map((u) => u.completed);
    const total = users.map((u) => u.total);

    new Chart(canvas.getContext("2d"), {
      type: "bar",
      data: {
        labels: labels,
        datasets: [
          {
            label: "Completed Tasks",
            data: completed,
            backgroundColor: "rgba(54, 162, 235, 0.9)",
            borderColor: "rgba(25, 118, 210, 1)",
            borderWidth: 1
          },
          {
            label: "Total Tasks",
            data: total,
            backgroundColor: "rgba(220, 230, 240, 0.6)",
            borderColor: "rgba(180, 195, 210, 1)",
            borderWidth: 1
          },
        ],
      },
      options: {
        responsive: true,
        scales: {
          x: {
            stacked: true,
            beginAtZero: true,
            ticks: { stepSize: 1 }
          },
          y: {
            stacked: true,
            ticks: { stepSize: 1 }
          }
        }
      }
    });

  });

  const departmentPieData = <%- JSON.stringify(pieChart) %>;

  Object.entries(departmentPieData).forEach(([department, rows]) => {
    const canvas = document.getElementById(`${department}PieChart`);
    if (!canvas) return;

    const row = rows[0];

    const labels = ["Completed", "Stuck", "Remaining"];
    const completed = row.completed_tasks || 0;
    const stuck = row.stuck_tasks || 0;
    const remaining = (row.total_tasks || 0) - completed - stuck;

    const data = [completed, stuck, remaining];

    const colors = ['#28a745', '#dc3545', '#ffc107'];

    new Chart(canvas.getContext('2d'), {
      type: 'doughnut',
      data: {
        labels: labels,
        datasets: [{
          data: data,
          backgroundColor: colors
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false, 
        plugins: {
          tooltip: { enabled: true },
          legend: { position: 'bottom' }
        }
      }
    });
  });
</script>
<%- include("../views/partials/footer.ejs") %>
