<%- include("../views/partials/header.ejs") %>
<main>
  <div class="container my-5">
    <div class="card">
      <div class="card-header">
        <h1 class="text-center">Live Updates</h1>
      </div>
      <div class="card-body h-50">
        <% if (orgTasks.length === 0) { %>
          <p class="text-center">No tasks have been assigned in your organization.</p>
        <% } else { %>
            <table class="table">
                <thead>
                    <tr>
                      <th scope="col">Assigned By</th>
                      <th scope="col">Assigned To</th>
                      <th scope="col">Task</th>
                      <th scope="col">Status</th>
                      <th scope="col">Due Date</th>
                      <th scope="col">Priority</th>
                      <th scope="col">Updated At</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% orgTasks.forEach(task => { 
                         const dueDate = task.due_date.toDateString().slice(4,15);
                         const updatedAt = task.updated_at 
                           ? new Date(task.updated_at).toLocaleString('en-US', {
                               month: 'short',
                               day: 'numeric',
                               year: 'numeric',
                               hour: '2-digit',
                               minute: '2-digit',
                               hour12: true
                             }) 
                           : '-';
                    %>
                      <tr>
                        <td><%= task.created_by %></td>
                        <td><%= task.created_for %></td>
                        <td><%= task.title %></td>
                        <td><%= task.status %></td>
                        <td><%= dueDate %></td>
                        <td><%= task.priority %></td>
                        <td><%= updatedAt %></td>
                      </tr>
                    <% }) %>
                  </tbody>
                </table>
        <% } %>
      </div>
    </div>
  </div>
</main>
<%- include("../views/partials/footer.ejs") %>