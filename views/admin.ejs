<%- include("../views/partials/header.ejs") %>

<main class="container my-5">

<% if(currentProfile.organization_id === null) { %>

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow">
      <div class="card-body text-center">
        <h3>Create Your Organization</h3>

        <form action="/admin" method="POST" class="mt-4">
          <div class="mb-3">
            <label class="form-label">Organization Name</label>
            <input type="text" class="form-control" name="orgName" required>
          </div>

          <button class="btn btn-primary w-100" style="color: black;">
            Create Organization
          </button>
        </form>

      </div>
    </div>
  </div>
</div>

<% } else { %>

<div class="mb-4 text-center">
  <h2><%= org.org_name %></h2>
  <p class="text-muted">Join Code: <strong><%= org.join_code %></strong></p>
</div>

<div class="row">

<!-- Sidebar -->
<div class="col-md-3">

<div class="list-group">

<button class="list-group-item list-group-item-action admin-btn" data-form="manager">
Add Manager
</button>

<button class="list-group-item list-group-item-action admin-btn" data-form="supervisor">
Add Supervisor
</button>

<button class="list-group-item list-group-item-action admin-btn" data-form="associate">
Add Associate
</button>

<button class="list-group-item list-group-item-action">
Add Department
</button>

<button class="list-group-item list-group-item-action">
Edit User Role
</button>

<button class="list-group-item list-group-item-action">
Configure Permissions
</button>

<button class="list-group-item list-group-item-action">
View Activity Logs
</button>

<button class="list-group-item list-group-item-action">
Organization Members
</button>

</div>
</div>


<!-- Forms Panel -->
<div class="col-md-9">

<div class="card shadow">
<div class="card-body">

<!-- Manager Form -->
<form action="/admin/create-manager" method="POST" class="admin-form" id="managerForm">

<h4 class="mb-3">Create Manager</h4>

<div class="row">

<div class="col-md-6 mb-3">
<label class="form-label">Email</label>
<input type="email" class="form-control" name="manEmail" required>
</div>

<div class="col-md-6 mb-3">
<label class="form-label">Temporary Password</label>
<input type="text" class="form-control" name="manPassword" required>
</div>

<div class="col-md-6 mb-3">
<label class="form-label">First Name</label>
<input type="text" class="form-control" name="manFirst" required>
</div>

<div class="col-md-6 mb-3">
<label class="form-label">Last Name</label>
<input type="text" class="form-control" name="manLast" required>
</div>

</div>

<button class="btn btn-primary" style="color: black;">
Create Manager
</button>

</form>


<!-- Supervisor Form -->
<form action="/admin/create-supervisor" method="POST" class="admin-form d-none" id="supervisorForm">

<h4 class="mb-3">Create Supervisor</h4>

<div class="row">

<div class="col-md-6 mb-3">
<label class="form-label">Email</label>
<input type="email" class="form-control" name="supeEmail" required>
</div>

<div class="col-md-6 mb-3">
<label class="form-label">Temporary Password</label>
<input type="text" class="form-control" name="supePassword" required>
</div>

<div class="col-md-6 mb-3">
<label class="form-label">First Name</label>
<input type="text" class="form-control" name="supeFirst" required>
</div>

<div class="col-md-6 mb-3">
<label class="form-label">Last Name</label>
<input type="text" class="form-control" name="supeLast" required>
</div>

<div class="col-md-6 mb-3">
<label class="form-label">Department</label>
<input type="text" class="form-control" name="supeDepartment" required>
</div>

</div>

<button class="btn btn-primary" style="color: black;">
Create Supervisor
</button>

</form>


<!-- Associate Form -->
<form action="/admin/create-associate" method="POST" class="admin-form d-none" id="associateForm">

<h4 class="mb-3">Create Associate</h4>

<div class="row">

<div class="col-md-6 mb-3">
<label class="form-label">Email</label>
<input type="email" class="form-control" name="empEmail" required>
</div>

<div class="col-md-6 mb-3">
<label class="form-label">Temporary Password</label>
<input type="text" class="form-control" name="empPassword" required>
</div>

<div class="col-md-6 mb-3">
<label class="form-label">First Name</label>
<input type="text" class="form-control" name="empFirst" required>
</div>

<div class="col-md-6 mb-3">
<label class="form-label">Last Name</label>
<input type="text" class="form-control" name="empLast" required>
</div>

<div class="col-md-6 mb-3">
<label class="form-label">Department</label>
<input type="text" class="form-control" name="empDepartment" required>
</div>

</div>

<button class="btn btn-primary" style="color: black;">
Create Associate
</button>

</form>

<!-- Department Form -->
 

</div>
</div>

</div>

</div>

<% } %>

</main>

<script>

const buttons = document.querySelectorAll(".admin-btn");
const forms = document.querySelectorAll(".admin-form");

buttons.forEach(btn => {

btn.addEventListener("click", () => {

forms.forEach(f => f.classList.add("d-none"));

const form = document.getElementById(btn.dataset.form + "Form");

if(form) form.classList.remove("d-none");

});

});

</script>

<%- include("../views/partials/footer.ejs") %>